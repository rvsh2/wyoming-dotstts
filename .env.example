DOTSTTS_MODEL=rednote-hilab/dots.tts-mf
DOTSTTS_DEVICE=cuda
DOTSTTS_PRECISION=bfloat16
DOTSTTS_NUM_STEPS=4
DOTSTTS_GUIDANCE_SCALE=1.2
# Voice profile used when a request names none (falls back to the first
# profile in DOTSTTS_SPEAKER_DIR when unset).
#DOTSTTS_DEFAULT_VOICE=mira
# Language advertised to Home Assistant; unset = a broad multilingual list.
#DOTSTTS_LANGUAGE=pl
DOTSTTS_SPEAKER_DIR=/data/speakers
DOTSTTS_MODEL_DIR=/data/models
WYOMING_URI=tcp://0.0.0.0:10201
HTTP_HOST=0.0.0.0
HTTP_PORT=8180
